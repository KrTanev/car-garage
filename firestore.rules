rules_version = '2';

// There is no backend server in this app — these rules ARE the entire
// access-control layer. The client talks to Firestore directly, so
// anything not explicitly allowed here is enforced, not optional.
//
// Admin model: there is no public sign-up. Every account that exists in
// Firebase Authentication is trusted staff (created by hand in the
// Firebase Console). So "request.auth != null" effectively means
// "signed-in staff member" throughout.
service cloud.firestore {
  match /databases/{database}/documents {

    // Generated invoices. Readable/creatable/editable by any signed-in
    // staff member — any account that exists is trusted, so one staffer
    // can fix another's typo. The one thing nobody can do is reassign an
    // invoice's createdBy to someone else. "Deleting" from the app is a
    // soft delete (an update that sets deletedAt) — hard delete is
    // blocked entirely here, so data can only be truly removed by hand
    // in the Firebase console, never by the client.
    match /invoices/{invoiceId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.createdBy == request.auth.uid;
      allow update: if request.auth != null
        && request.resource.data.createdBy == resource.data.createdBy;
      allow delete: if false;
    }

    // Per-year invoice number counters (doc id = the year, e.g. "2026").
    // The atomic increment itself happens client-side inside a Firestore
    // transaction (see invoiceStore.ts), but the rules also enforce the
    // shape directly: lastNumber must be a positive integer that only ever
    // moves forward, so a buggy or malicious client can't reset it, set it
    // negative, or overwrite it with a non-numeric value.
    match /counters/{year} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.data.lastNumber is int
        && request.resource.data.lastNumber > 0
        && (resource == null || request.resource.data.lastNumber > resource.data.lastNumber);
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
