rules_version = '2';

// There is no backend server in this app — these rules ARE the entire
// access-control layer. The client talks to Firestore directly, so
// anything not explicitly allowed here is enforced, not optional.
//
// Admin model: there is no public sign-up. Every account that exists in
// Firebase Authentication is trusted staff (created by hand in the
// Firebase Console). So "request.auth != null" effectively means
// "signed-in staff member" throughout.
service cloud.firestore {
  match /databases/{database}/documents {

    // Generated invoices. Readable/creatable by any signed-in staff
    // member. Immutable once created — no edits or deletes from the
    // client, so the history can't be silently altered after the fact.
    match /invoices/{invoiceId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.createdBy == request.auth.uid;
      allow update, delete: if false;
    }

    // Per-year invoice number counters (doc id = the year, e.g. "2026").
    // Read/write requires sign-in; the atomic increment itself happens
    // client-side inside a Firestore transaction (see invoiceStore.ts).
    match /counters/{year} {
      allow read, write: if request.auth != null;
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
